# Data (large; regenerate with abx-download)
data/raw/*
data/processed/*
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# Keep committed figures so README embeds render on GitHub
# (pipeline regenerates them; commit when they change)
# reports/figures/*.png are tracked

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.parquet
.DS_Store
.ipynb_checkpoints/
*.log
